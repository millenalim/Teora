generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  fullName     String   @default("")
  avatarUrl    String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  HomeMember[]
  createdTasks Task[]       @relation("TaskCreatedBy")

  @@map("users")
}

// ─────────────────────────────────────────────
// HOMES
// ─────────────────────────────────────────────

model Home {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  sqft        Int?
  lotSize     String?
  purpose     String?
  description String?
  colorTag    String   @default("#6366f1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        HomeMember[]
  tasks          Task[]
  events         Event[]
  completionLogs CompletionLog[]

  @@map("homes")
}

// role: owner | admin | manager | viewer
model HomeMember {
  id       Int      @id @default(autoincrement())
  homeId   Int
  userId   Int
  role     String   @default("viewer")
  joinedAt DateTime @default(now())

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([homeId, userId])
  @@map("home_members")
}

// ─────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────

// status: todo | inprogress | review | done
// priority: high | medium | low
model Task {
  id          Int      @id @default(autoincrement())
  homeId      Int
  title       String
  description String?
  status      String   @default("todo")
  priority    String   @default("medium")
  startDate   DateTime?
  endDate     DateTime?
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  home      Home           @relation(fields: [homeId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignees TaskAssignee[]

  @@index([homeId, status])
  @@map("tasks")
}

model TaskAssignee {
  id       Int  @id @default(autoincrement())
  taskId   Int
  memberId Int  // HomeMember.id

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, memberId])
  @@map("task_assignees")
}

// ─────────────────────────────────────────────
// EVENTS
// ─────────────────────────────────────────────

model Event {
  id        Int       @id @default(autoincrement())
  homeId    Int
  title     String
  startDate DateTime?
  endDate   DateTime?
  startTime String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@index([homeId, startDate])
  @@map("events")
}

// ─────────────────────────────────────────────
// COMPLETION LOGS (polymorphic)
// ─────────────────────────────────────────────

// entityType: maintenance | event | network | warranty | contact |
//             utility | smart_home | emergency | protocol
model CompletionLog {
  id            Int      @id @default(autoincrement())
  entityType    String
  entityId      Int
  homeId        Int
  completedDate DateTime
  completedById Int?     // HomeMember.id — resolved to user at read time
  cost          String?
  notes         String?
  createdAt     DateTime @default(now())

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([homeId])
  @@map("completion_logs")
}
