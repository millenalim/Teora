// MiHomes — Prisma Schema
// Reference document. Actual file lives at prisma/schema.prisma in the project root.
// Database: SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")  // "file:./dev.db"
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  email         String   @unique
  fullName      String   @default("")
  avatarUrl     String?
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  memberships   HomeMember[]
  createdTasks  Task[]         @relation("TaskCreatedBy")
  uploadedDocs  Document[]
  activityLogs  ActivityLog[]
  bulletins     Bulletin[]
  notifications Notification[]
  accessLogs    AccessLog[]

  @@map("users")
}

// NextAuth required tables
model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// HOMES
// ─────────────────────────────────────────────

model Home {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  sqft        Int?
  lotSize     String?
  purpose     String?
  description String?
  colorTag    String   @default("#6366f1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members           HomeMember[]
  tasks             Task[]
  events            Event[]
  documents         Document[]
  people            Person[]
  vendorHomes       VendorHome[]
  maintenanceTasks  MaintenanceTask[]
  serviceProviders  ServiceProvider[]
  lockCodes         LockCode[]
  networks          InternetNetwork[]
  warranties        ApplianceWarranty[]
  contacts          ImportantContact[]
  utilities         UtilityBill[]
  smartHomeSystems  SmartHomeSystem[]
  emergencyInfos    EmergencyInfo[]
  completionLogs    CompletionLog[]
  activityLogs      ActivityLog[]
  bulletins         Bulletin[]
  protocols         Protocol[]
  lists             List[]
  notifications     Notification[]
  accessLogs        AccessLog[]

  @@map("homes")
}

// Role: owner | admin | manager | viewer
model HomeMember {
  id        Int      @id @default(autoincrement())
  homeId    Int
  userId    Int
  role      String   @default("viewer")
  joinedAt  DateTime @default(now())
  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([homeId, userId])
  @@map("home_members")
}

// ─────────────────────────────────────────────
// PEOPLE
// ─────────────────────────────────────────────

// Role: resident | staff | contact
model Person {
  id        Int      @id @default(autoincrement())
  homeId    Int
  name      String
  role      String
  phone     String?
  email     String?
  company   String?
  notes     String?
  userId    Int?     // linked app user (optional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  taskAssignees   TaskAssignee[]
  completionLogs  CompletionLog[]
  eventAssignees  Event[]

  @@map("people")
}

// ─────────────────────────────────────────────
// VENDORS
// ─────────────────────────────────────────────

model Vendor {
  id           Int          @id @default(autoincrement())
  companyName  String
  serviceType  String?
  phone        String?
  email        String?
  website      String?
  pricing      String?
  quoteAmount  Decimal?
  rating       Int?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  vendorHomes  VendorHome[]

  @@map("vendors")
}

model VendorHome {
  id       Int    @id @default(autoincrement())
  vendorId Int
  homeId   Int
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  home     Home   @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@unique([vendorId, homeId])
  @@map("vendor_homes")
}

// ─────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────

// Status: todo | inprogress | review | done
// Priority: high | medium | low
model Task {
  id          Int            @id @default(autoincrement())
  homeId      Int
  title       String
  description String?
  status      String         @default("todo")
  priority    String         @default("medium")
  startDate   DateTime?
  endDate     DateTime?
  createdById Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  home        Home           @relation(fields: [homeId], references: [id], onDelete: Cascade)
  createdBy   User?          @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignees   TaskAssignee[]

  @@map("tasks")
}

model TaskAssignee {
  id       Int    @id @default(autoincrement())
  taskId   Int
  personId Int
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([taskId, personId])
  @@map("task_assignees")
}

// ─────────────────────────────────────────────
// EVENTS
// ─────────────────────────────────────────────

model Event {
  id         Int       @id @default(autoincrement())
  homeId     Int
  title      String
  assigneeId Int?
  startDate  DateTime?
  endDate    DateTime?
  startTime  String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  home       Home      @relation(fields: [homeId], references: [id], onDelete: Cascade)
  assignee   Person?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@map("events")
}

// ─────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────

// Category: contract | insurance | manual | protocol | receipt | tax | other
model Document {
  id           Int      @id @default(autoincrement())
  homeId       Int
  title        String
  category     String   @default("other")
  filePath     String   // path under /uploads/
  notes        String?
  docDate      DateTime?
  uploadedById Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  home         Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@map("documents")
}

// ─────────────────────────────────────────────
// MAINTENANCE
// ─────────────────────────────────────────────

// Frequency: weekly | biweekly | monthly | quarterly | semiannually | annually | as_needed
model MaintenanceTask {
  id            Int       @id @default(autoincrement())
  homeId        Int
  taskName      String
  frequency     String    @default("as_needed")
  provider      String?
  estimatedCost Decimal?
  notes         String?
  nextDue       DateTime? // auto-calculated from last completion + frequency
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  home          Home      @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("maintenance_tasks")
}

// ─────────────────────────────────────────────
// HOME INFO SECTIONS
// ─────────────────────────────────────────────

model ServiceProvider {
  id          Int      @id @default(autoincrement())
  homeId      Int
  name        String
  serviceType String?
  phone       String?
  email       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  home        Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("service_providers")
}

// lockType: smart_lock | keypad | gate | garage | lockbox | other
model LockCode {
  id             Int      @id @default(autoincrement())
  homeId         Int
  location       String
  codeEncrypted  String   // AES-256 encrypted — never returned in standard responses
  lockType       String   @default("other")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  home           Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("lock_codes")
}

model InternetNetwork {
  id                   Int      @id @default(autoincrement())
  homeId               Int
  provider             String?
  accountNumber        String?
  planDetails          String?
  wifiName             String?
  wifiPasswordEncrypted String? // AES-256 encrypted
  routerIp             String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  home                 Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("internet_networks")
}

model ApplianceWarranty {
  id             Int       @id @default(autoincrement())
  homeId         Int
  appliance      String
  brand          String?
  model          String?
  serialNumber   String?
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  purchasedFrom  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  home           Home      @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("appliance_warranties")
}

// contactType: hoa | insurance | mortgage | pest_control | landscaping | pool | security | other
model ImportantContact {
  id            Int      @id @default(autoincrement())
  homeId        Int
  name          String
  contactType   String   @default("other")
  phone         String?
  email         String?
  accountNumber String?
  policyNumber  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  home          Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("important_contacts")
}

// utilityType: electric | gas | water | sewer | trash | internet | solar | other
model UtilityBill {
  id             Int      @id @default(autoincrement())
  homeId         Int
  utilityType    String
  provider       String?
  accountNumber  String?
  avgMonthlyCost Decimal?
  dueDate        String?  // e.g. "15th of each month"
  autopay        Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  home           Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("utility_bills")
}

model SmartHomeSystem {
  id               Int      @id @default(autoincrement())
  homeId           Int
  systemName       String
  appName          String?
  hubModel         String?
  accountEmail     String?
  connectedDevices String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  home             Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("smart_home_systems")
}

model EmergencyInfo {
  id        Int      @id @default(autoincrement())
  homeId    Int
  item      String   // e.g. "Main water shutoff"
  location  String?
  details   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("emergency_info")
}

// ─────────────────────────────────────────────
// COMPLETION LOGS (polymorphic)
// ─────────────────────────────────────────────

// entityType: maintenance | event | network | warranty | contact |
//             utility | smart_home | emergency | protocol
model CompletionLog {
  id            Int       @id @default(autoincrement())
  entityType    String
  entityId      Int
  homeId        Int
  completedDate DateTime
  completedById Int?
  cost          String?   // free text: "$150", "included in contract"
  notes         String?
  createdAt     DateTime  @default(now())
  home          Home      @relation(fields: [homeId], references: [id], onDelete: Cascade)
  completedBy   Person?   @relation(fields: [completedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([homeId])
  @@map("completion_logs")
}

// ─────────────────────────────────────────────
// SENSITIVE DATA ACCESS LOG (read-only audit)
// ─────────────────────────────────────────────

// entityType: lock_code | wifi_password
model AccessLog {
  id         Int      @id @default(autoincrement())
  homeId     Int
  userId     Int
  entityType String
  entityId   Int
  ipAddress  String?
  userAgent  String?
  accessedAt DateTime @default(now())
  home       Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([homeId])
  @@index([userId])
  @@map("access_logs")
}

// ─────────────────────────────────────────────
// COMMUNICATION & COLLABORATION
// ─────────────────────────────────────────────

model ActivityLog {
  id        Int      @id @default(autoincrement())
  homeId    Int
  authorId  Int?
  content   String   // raw text with @Name mentions
  createdAt DateTime @default(now())
  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([homeId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

model Bulletin {
  id        Int      @id @default(autoincrement())
  homeId    Int
  title     String
  content   String
  authorId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@map("bulletins")
}

// category: emergency | cleaning | opening_closing | security | guest | maintenance | other
model Protocol {
  id               Int       @id @default(autoincrement())
  homeId           Int
  title            String
  category         String    @default("other")
  content          String?
  linkedDocName    String?
  lastReviewedDate DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  home             Home      @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("protocols")
}

model List {
  id        Int        @id @default(autoincrement())
  homeId    Int
  title     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  home      Home       @relation(fields: [homeId], references: [id], onDelete: Cascade)
  items     ListItem[]

  @@map("lists")
}

model ListItem {
  id        Int      @id @default(autoincrement())
  listId    Int
  text      String
  done      Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@map("list_items")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

// type: maintenance_overdue | maintenance_due_soon | warranty_expiring |
//       task_assigned | task_due_soon | event_reminder | bulletin_posted | mention
model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  homeId     Int?
  type       String
  title      String
  body       String?
  entityType String?  // "maintenance", "task", etc.
  entityId   Int?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  home       Home?    @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}
